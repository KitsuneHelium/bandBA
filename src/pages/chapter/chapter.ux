  width: 300px;
  height: 80px;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.6);
  padding: 0 15px;
  margin-bottom: 10px;
  border-radius: 36px;
}


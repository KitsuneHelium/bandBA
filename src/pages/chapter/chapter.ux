  background-color: rgb(0, 153, 255);
  color: rgba(255, 255, 255, 0.897);
  border-radius: 20px;
  font-size: 24px;
}

.empty-tip {
  color: rgb(44, 44, 44);
  font-size: 24px;
  text-align: center;
  margin-top: 20px;
}

.more {
  font-size: 14px;
  margin: 20px 0;
}

.exit_btn {
  top:10px;
  left:10px;
  position: absolute;
  width: 60px;
  height: 60px;
  font-size: 26px;
  margin: 5px;
  background-color: #ffffffa4;
  color: #000000;
  border-radius: 36px;
  margin-bottom: 10px;
}
.go_btn {
  width: 100px;
  height: 40px;
  background-color: #666;

        <!-- <div class="controls">
          <input type="button" class="btn" onclick="playJump" value="跳跃" />
          <input type="button" class="btn" onclick="playShakeX" value="抖动" />
          <input type="button" class="btn btn-stop" onclick="stopAllAnimations" value="停止" />
          
        </div> -->
      </scroll>
      </div>
    </div>
  </template>
  
  <script>
  import router from "@system.router";
  
  export default {
    data: {
      bgO:0,
      charaAnimClass: "",
      animTimer: null
    },
    onShow() {
      this.bgO = 1;
    },
    back() {
      this.bgO = 0;
      router.back();
    },
    exit(){
      this.bgO = 0;
        router.back();
    },
    stopAllAnimations() {
      if (this.animTimer) clearTimeout(this.animTimer);
      this.charaAnimClass = "";
    },
  
    playJump() {
      this.stopAllAnimations();
      this.charaAnimClass = "anim-jump-up";
      this.animTimer = setTimeout(() => {
        this.charaAnimClass = "anim-jump-down";
        setTimeout(() => {
          this.charaAnimClass = "";
        }, 250);
      }, 250);
    },
  
    // ========== 核心修改：最后一步执行复位空动画 ==========
    playShakeX() {
      this.stopAllAnimations();
      let count = 0;
      const shake = () => {
        if (count >= 4) { // 恢复原4次循环，不用提前终止
          // 第一步：执行复位空动画（强制锁定到0px）
          this.charaAnimClass = "anim-reset-x";
          // 等空动画跑完（哪怕只有1ms，也能触发引擎复位）
          setTimeout(() => {
            this.charaAnimClass = "";
          }, 10); // 极短时长，无感知但能触发复位
          return;
        }
  
        // 正常抖动循环：0(left)→1(right)→2(left)→3(right)
        this.charaAnimClass = count % 2 === 0 ? "anim-shake-left" : "anim-shake-right";
        count++;
        this.animTimer = setTimeout(shake, 75);
      };
      shake();
    }
  }
  </script>
  
  <style>
  .title {
  position: absolute;
  top:15px;
  right: 20px;
  font-size: 36px;
  font-weight: bold;
  align-self: flex-start;
}

